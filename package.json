{
  "version": "1.4.3",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "typings": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18.12"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": "prettier --write"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "10 KB"
    }
  ],
  "scripts": {
    "start": "nodemon playground",
    "watch": "tsup --watch",
    "build": "tsup",
    "test": "node --import tsx --test test/genRecurDateBasedList-step.test.ts test/genRecurDateBasedList-cron.test.ts test/genRecurDateBasedList-edge.test.ts test/formatDate.test.ts test/outputFormats.test.ts",
    "size": "size-limit",
    "format": "cd src && pnpx prettier --write .",
    "cleardeps": "rm -rf node_modules",
    "prepare": "husky"
  },
  "name": "recur-date-based",
  "author": "Michael Navasardyan",
  "keywords": [
    "recurrence",
    "recurring days",
    "extended props",
    "expanded properties",
    "events",
    "repeating dates",
    "date generation",
    "multiple occurrences",
    "date properties",
    "date manipulation",
    "date utility",
    "date calculations",
    "past dates",
    "future dates",
    "scheduling",
    "backward",
    "pattern"
  ],
  "description": "Generate recurring dates and extra props based on them.",
  "devDependencies": {
    "@size-limit/file": "^11.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "size-limit": "^11.2.0",
    "tslib": "^2.8.1",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
